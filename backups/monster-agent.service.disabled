[Unit]
Description=L99 APEX BRAIN — Single Unified Trading Bot (BTC/ETH/XRP/SOL/BNB/ADA) 24/7
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Environment=ENABLE_AGENT_THINKING_STREAM=1
Environment=ENABLE_CONFIDENCE_VISUALIZATION=1
Environment=ENABLE_DECISION_LOGIC_STREAM=1
Environment=ENABLE_SIGNAL_EVOLUTION_TRACKING=1
Environment=ENABLE_THINKING_STATES=1
Environment=ENABLE_REGIME_TRANSITIONS=1
Environment=ENABLE_REGIME_ALERTS=1
Environment=ENABLE_MARKET_MOOD_ENGINE=1
Environment=ENABLE_CINEMATIC_FEED=1
Environment=ENABLE_AGENT_THOUGHTS=1
Environment=ENABLE_REALTIME_REASONING=1
Environment=ENABLE_AGENT_AURA_EFFECTS=1
Environment=ENABLE_LIVE_CONFIDENCE_GLOW=1
Environment=ENABLE_DYNAMIC_CARD_PULSES=1
Environment=ENABLE_THREAT_ANALYSIS=1
Environment=ENABLE_MOMENTUM_WARNINGS=1
Environment=ENABLE_DOMINATION_STREAKS=1
Environment=ENABLE_COMEBACK_ALERTS=1
Environment=ENABLE_RISK_REASONING=1
Environment=ENABLE_DRAWDOWN_WARNINGS=1
Environment=ENABLE_EXPOSURE_VISUALS=1
Environment=ENABLE_EXTENDED_TELEMETRY=1
Environment=ENABLE_AGENT_MEMORY_STREAM=1
Environment=ENABLE_DYNAMIC_POSITION_SCALING=1
Environment=LOW_CONF_POSITION_MULT=0.50
Environment=NORMAL_POSITION_MULT=1.00
Environment=HIGH_CONF_POSITION_MULT=1.40
Environment=ELITE_POSITION_MULT=1.75
Environment=HIGH_CONFIDENCE_THRESHOLD=85
Environment=ELITE_CONFIDENCE_THRESHOLD=92
Environment=MAX_RISK_PER_TRADE=0.005
Environment=MAX_TOTAL_EXPOSURE=0.30
Environment=ENABLE_PYRAMIDING=1
Environment=MAX_PYRAMID_LAYERS=2
Environment=PYRAMID_ONLY_ON_PROFIT=1
Environment=ENABLE_DRAWDOWN_COMPRESSION=1
Environment=MAX_SESSION_DD=0.05
Type=simple
WorkingDirectory=/root/ai-l99-production
Environment=PYTHONPATH=/root/ai-l99-production/strategy_lab
Environment=BOT_ID=A
Environment=BOT_PAIRS=BTC/USDT,ETH/USDT,XRP/USDT,SOL/USDT,BNB/USDT,ADA/USDT
Environment=BOT_LOG=runtime/agent_A.log
Environment=BOT_STATE=runtime/agent_A_state.json
ExecStart=/root/ai-l99-production/venv/bin/python /root/ai-l99-production/strategy_lab/agent.py
Restart=always
RestartSec=3
StartLimitBurst=0
KillMode=mixed
TimeoutStopSec=10
OOMScoreAdjust=-900
CPUSchedulingPolicy=other
Nice=-10
LimitNOFILE=65536
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
