# Obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.trash/

# OS
.DS_Store
._.DS_Store
__MACOSX/

# Secrets (never commit)
*.env
*.api_key
*.pem
*.key
credentials.json
secrets.json

# Large files
*.zip
*.tar.gz
*.7z

# Codex workspace artifacts (sync from vault, not vault content)
sync.log

# Obsidian plugin compiled files (third-party, may contain OAuth client IDs)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/obsidian_askpass.sh

# GitHub workflows (from old code dump, not vault content)
.github/workflows/
