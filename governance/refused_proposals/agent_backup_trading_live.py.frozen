RTSL_ATR_LOW_MULT     = 0.8     # if ATR < 0.8% of price -> tight, tighten SL
RTSL_ATR_TP_BONUS     = 0.010   # +1.0% added to TP in high-vol market
RTSL_ATR_SL_TIGHTEN   = 0.003   # SL reduced by 0.3% in low-vol market

# --- Momentum Reversal SL ---
