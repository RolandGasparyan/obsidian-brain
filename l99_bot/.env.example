# Copy to .env and fill in real values — never commit .env to git

# ── Exchange (Gate.io) ────────────────────────────────
GATE_API_KEY=your_gate_api_key
GATE_API_SECRET=your_gate_api_secret
TESTNET=true
LIVE_TRADING=false

# ── Risk (testnet stage) ─────────────────────────────
RISK_PER_TRADE=0.01
MAX_CONCURRENT=3
KILL_DD_THRESHOLD=0.21

# ── Database ─────────────────────────────────────────
DB_NAME=l99
DB_USER=l99_user
DB_PASS=change_this_strong_password
DB_HOST=localhost
DB_PORT=5432
# NOTE: env var is DB_PASS (not DB_PASSWORD)

# ── Telegram ─────────────────────────────────────────
TELEGRAM_TOKEN=1234567890:ABCDEFxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_integer

# ── Governance / Redundancy (keep false until authorized) ──
GOVERNANCE_ENABLED=false
REDUNDANCY_ENABLED=false
